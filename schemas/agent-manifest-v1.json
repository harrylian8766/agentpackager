{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentpackager.dev/schemas/agent-manifest-v1.json",
  "title": "AgentPackager Manifest v1",
  "description": "Declarative specification for packaging an AI agent's capabilities into secure, multi-protocol service interfaces.",
  "type": "object",
  "required": ["name", "version", "capabilities"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Unique agent name. Use kebab-case or PascalCase."
    },
    "displayName": {
      "type": "string",
      "maxLength": 128,
      "description": "Human-readable display name."
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "What this agent does."
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$",
      "description": "SemVer version string."
    },
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "icon": {
      "type": "string",
      "format": "uri",
      "description": "Agent icon URL (square, 512x512 recommended)."
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier (e.g., MIT, Apache-2.0)."
    },
    "repository": {
      "type": "string",
      "format": "uri",
      "description": "Source code repository URL."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "maxLength": 50 },
      "maxItems": 20,
      "description": "Searchable capability tags."
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "inputSchema", "outputSchema"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-zA-Z0-9_-]*$",
            "maxLength": 64,
            "description": "Unique capability ID within this agent."
          },
          "name": {
            "type": "string",
            "maxLength": 128,
            "description": "Human-readable capability name."
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "description": "What this capability does."
          },
          "inputSchema": {
            "$ref": "http://json-schema.org/draft-07/schema#",
            "description": "JSON Schema for the capability's input parameters."
          },
          "outputSchema": {
            "$ref": "http://json-schema.org/draft-07/schema#",
            "description": "JSON Schema for the capability's output."
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "input": {},
                "output": {}
              }
            },
            "description": "Example input/output pairs for documentation."
          }
        }
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "sandbox": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["docker", "gvisor", "firecracker", "wasm", "process"],
              "description": "Sandbox isolation technology."
            },
            "network": {
              "type": "string",
              "enum": ["none", "restricted", "full"],
              "default": "restricted"
            },
            "allowedDomains": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Outbound network whitelist (when network=restricted)."
            },
            "filesystem": {
              "type": "string",
              "enum": ["none", "readonly", "ephemeral", "full"],
              "default": "ephemeral"
            },
            "executionTimeout": {
              "type": "string",
              "pattern": "^[0-9]+[smhd]$",
              "default": "30s",
              "description": "Max execution time (e.g., 30s, 5m, 1h)."
            },
            "maxMemory": {
              "type": "string",
              "pattern": "^[0-9]+[KMGT]?i?B$",
              "default": "512MiB",
              "description": "Max memory (e.g., 512MiB, 2GiB)."
            },
            "maxCpu": {
              "type": "string",
              "pattern": "^[0-9]+(\\\\.[0-9]+)?$",
              "default": "1",
              "description": "Max CPU cores."
            }
          }
        },
        "rateLimit": {
          "type": "object",
          "properties": {
            "requestsPerMinute": {
              "type": "integer",
              "minimum": 1,
              "default": 60
            },
            "requestsPerHour": {
              "type": "integer",
              "minimum": 1
            },
            "requestsPerDay": {
              "type": "integer",
              "minimum": 1
            },
            "concurrentRequests": {
              "type": "integer",
              "minimum": 1,
              "default": 10
            }
          }
        },
        "dataProtection": {
          "type": "object",
          "properties": {
            "inputLogging": {
              "type": "boolean",
              "default": false,
              "description": "Whether to log user inputs."
            },
            "outputLogging": {
              "type": "boolean",
              "default": true,
              "description": "Whether to log outputs for audit."
            },
            "piiRedaction": {
              "type": "boolean",
              "default": true,
              "description": "Auto-redact PII (phone, ID, email, etc)."
            },
            "encryption": {
              "type": "string",
              "enum": ["none", "tls", "e2e"],
              "default": "tls",
              "description": "Transport encryption level."
            }
          }
        },
        "authentication": {
          "type": "object",
          "properties": {
            "methods": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["api_key", "oauth2", "jwt", "pairing"]
              },
              "default": ["api_key"]
            },
            "apiKeyRotation": {
              "type": "boolean",
              "default": true
            },
            "autoAcceptPairing": {
              "type": "boolean",
              "default": false,
              "description": "Auto-accept incoming pairing requests (dangerous)."
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["docker", "binary", "python", "node", "wasm"],
          "default": "docker"
        },
        "image": {
          "type": "string",
          "description": "Docker image (when type=docker)."
        },
        "command": {
          "type": "string",
          "description": "Entrypoint command (when type=binary/python/node)."
        },
        "env": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "string" },
              "secret": {
                "type": "boolean",
                "default": false,
                "description": "If true, value is a reference to a secret manager."
              }
            }
          }
        },
        "volumes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": { "type": "string" },
              "container": { "type": "string" },
              "readonly": { "type": "boolean", "default": true }
            }
          }
        },
        "healthCheck": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "default": "/health" },
            "interval": { "type": "string", "pattern": "^[0-9]+[smhd]$", "default": "30s" },
            "timeout": { "type": "string", "pattern": "^[0-9]+[smhd]$", "default": "5s" }
          }
        }
      }
    },
    "protocols": {
      "type": "object",
      "description": "Which protocols to expose. Omit = auto-generate all.",
      "properties": {
        "rest": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "basePath": { "type": "string", "default": "/api/v1" },
            "cors": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean", "default": true },
                "allowedOrigins": { "type": "array", "items": { "type": "string" }, "default": ["*"] }
              }
            }
          }
        },
        "mcp": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "serverName": { "type": "string" },
            "transport": {
              "type": "string",
              "enum": ["stdio", "http", "sse"],
              "default": "stdio"
            }
          }
        },
        "websocket": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "path": { "type": "string", "default": "/ws" }
          }
        },
        "webhook": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "path": { "type": "string", "default": "/webhook" },
            "events": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "platforms": {
      "type": "object",
      "description": "Third-party platform integrations.",
      "properties": {
        "aiPair": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "endpoint": { "type": "string", "format": "uri" }
          }
        },
        "discord": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false }
          }
        },
        "telegram": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false }
          }
        },
        "feishu": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false }
          }
        }
      }
    }
  }
}
