{
  "name": "agentpackager",
  "version": "0.1.0",
  "description": "Package your AI agent's capabilities into secure, multi-protocol service interfaces",
  "type": "module",
  "license": "MIT",
  "author": "Harry Lian <harry@aistock.hk>",
  "homepage": "https://github.com/harrylian8766/agentpackager",
