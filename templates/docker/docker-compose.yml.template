version: "3.8"

services:
  {{agentKebabName}}:
    build:
      context: .
      dockerfile: Dockerfile
      target: production
    image: {{agentKebabName}}:{{version}}
    container_name: {{agentKebabName}}
    ports:
      - "{{port}}:{{port}}"
    environment:
      - NODE_ENV=production
      - PORT={{port}}
{{envVars}}
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,size=100m
    healthcheck:
      test: ["CMD", "node", "-e", "require('http').get('http://localhost:{{port}}/health', (r) => r.statusCode === 200 ? process.exit(0) : process.exit(1))"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 5s

  # Optional: Nginx reverse proxy
  # nginx:
  #   image: nginx:alpine
  #   ports:
  #     - "80:80"
  #     - "443:443"
  #   volumes:
  #     - ./nginx.conf:/etc/nginx/nginx.conf:ro
  #   depends_on:
  #     - {{agentKebabName}}
